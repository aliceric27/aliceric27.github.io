@counter-style repeating-emoji {
  system: cyclic;
  symbols: "\1F4CD"; // unicode code point
  suffix: " ";
}
@font-face {
  font-family: Pingfun;
  src: url(/images/Pingfun.woff);
}
.post-body {
//font-family: 'Pingfun', sans-serif;
text-align:start;
font-size: 1rem;
font-weight: 500;
}

code{
  padding :0,1rem,0,1rem;
  background-color: #d5d5d5;
  color:#eb3f3f;
  font-weight: 500;

}

.note ul {
  list-style: disc; 
  padding-left: 1rem;
}
ul {
  list-style: disc; 
}

.note li  {
