@media screen and (min-width:1200px) {

    body {  
    //background-image:url(/images/20230228_155443.jpg); //這邊修改成你的背景圖片 
    background-repeat: no-repeat;
    background-attachment:fixed;
    background-position:50% 50%;
    background-size: cover;
   
   }

    #footer a {
        color:#eee;
    }
}



